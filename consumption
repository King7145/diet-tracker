<!DOCTYPE html>
<html lang="zh-HK">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>飲食記帳</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
  <style>
    :root {
      --ios-bg: #f2f2f7;
      --ios-surface: #ffffff;
      --ios-secondary-surface: #f2f2f7;
      --ios-primary-text: #000000;
      --ios-secondary-text: #8e8e93;
      --ios-accent: #007aff; /* iOS 經典藍 */
      --ios-accent-bg: #e5f1ff;
      --ios-danger: #ff3b30; /* iOS 經典紅 */
      --ios-danger-bg: #ffebeb;
      --ios-border: #d1d1d6;
    }

    *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
    body{font-family:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;background:var(--ios-bg);color:var(--ios-primary-text);padding-top:env(safe-area-inset-top)}
    
    .app{max-width:390px;margin:0 auto;min-height:100vh;display:flex;flex-direction:column;background:var(--ios-bg)}
    
    /* Header iOS Style */
    .header{background:var(--ios-surface);border-bottom:0.5px solid var(--ios-border);padding:14px 16px 12px;position:sticky;top:0;z-index:10}
    .header-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
    .month-nav{display:flex;align-items:center;gap:16px}
    .month-nav button{background:none;border:none;color:var(--ios-accent);font-size:22px;cursor:pointer;padding:2px 6px;font-weight:600}
    .month-title{font-size:17px;font-weight:600}
    .month-total{font-size:13px;color:var(--ios-accent);background:var(--ios-accent-bg);padding:4px 12px;border-radius:12px;font-weight:500}
    
    .weekdays{display:grid;grid-template-columns:repeat(7,1fr);text-align:center;font-size:11px;color:var(--ios-secondary-text);margin-bottom:6px;font-weight:500}
    .calendar{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
    .day-cell{aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;border-radius:8px;cursor:pointer;position:relative;padding:2px}
    .day-num{font-size:15px;line-height:1}
    .day-amt{font-size:9px;color:var(--ios-accent);margin-top:2px;line-height:1;font-weight:500}
    
    .day-cell.today .day-num {background:var(--ios-danger);color:#fff;width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:600}
    .day-cell.selected{background:var(--ios-accent-bg)}
    .day-cell.selected .day-num{color:var(--ios-accent);font-weight:600}
    .day-cell.other-month .day-num{color:var(--ios-border)}

    /* Content Area */
    .content{flex:1;padding:16px;overflow-y:auto;padding-bottom:calc(32px + env(safe-area-inset-bottom))}
    .date-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;padding:0 4px}
    .date-label{font-size:17px;font-weight:600;color:var(--ios-primary-text)}
    .day-total{font-size:17px;color:var(--ios-primary-text);font-weight:600}
    
    /* iOS Button Style */
    .add-btn{display:flex;align-items:center;justify-content:center;gap:6px;background:var(--ios-surface);color:var(--ios-accent);border:none;border-radius:10px;padding:12px;font-size:16px;font-weight:500;cursor:pointer;margin-bottom:16px;width:100%;box-shadow: 0 1px 2px rgba(0,0,0,0.05)}
    .add-btn:active{background:var(--ios-secondary-surface)}
    
    /* Stats Bar */
    .stats-bar{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:16px}
    .stat-card{background:var(--ios-surface);border-radius:10px;padding:10px 12px;box-shadow: 0 1px 2px rgba(0,0,0,0.05)}
    .stat-label{font-size:11px;color:var(--ios-secondary-text);margin-bottom:2px;font-weight:500}
    .stat-val{font-size:16px;font-weight:600}

    /* Meal Section & Cards */
    .meal-section{margin-bottom:16px}
    .meal-section-title{font-size:13px;color:var(--ios-secondary-text);font-weight:600;text-transform:uppercase;margin-bottom:6px;padding-left:4px;display:flex;align-items:center;gap:4px}
    .entry-card{background:var(--ios-surface);border-radius:12px;padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;box-shadow: 0 1px 2px rgba(0,0,0,0.05)}
    .entry-info{flex:1}
    .entry-name{font-size:16px;font-weight:500;margin-bottom:2px}
    .entry-meta{font-size:13px;color:var(--ios-secondary-text)}
    .entry-price{font-size:16px;font-weight:600;color:var(--ios-primary-text)}
    .entry-del{background:none;border:none;color:var(--ios-secondary-text);font-size:18px;cursor:pointer;padding:4px;border-radius:6px}
    .entry-del:active{color:var(--ios-danger);background:var(--ios-danger-bg)}
    
    .empty-state{text-align:center;padding:40px 20px;color:var(--ios-secondary-text)}
    .empty-state i{font-size:40px;margin-bottom:10px;display:block;color:var(--ios-border)}
    .empty-state p{font-size:14px}

    /* Modal iOS Action Sheet Style */
    .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:100;display:flex;align-items:flex-end;justify-content:center}
    .modal{background:var(--ios-bg);border-radius:12px 12px 0 0;padding:20px;width:100%;max-width:390px;max-height:90vh;overflow-y:auto;padding-bottom:calc(20px + env(safe-area-inset-bottom))}
    .modal-handle{width:36px;height:5px;background:var(--ios-border);border-radius:2.5px;margin:0 auto 16px;display:block}
    .modal-title{font-size:17px;font-weight:600;margin-bottom:16px;text-align:center}
    
    /* iOS Form Group (Form Rows) */
    .ios-list {background:var(--ios-surface);border-radius:10px;margin-bottom:20px;overflow:hidden}
    .form-group{padding:11px 16px;display:flex;align-items:center;border-bottom:0.5px solid #e5e5ea}
    .form-group:last-child{border-bottom:none}
    .form-label{font-size:15px;color:var(--ios-primary-text);width:90px;flex-shrink:0}
    .form-input{flex:1;background:none;border:none;padding:0;font-size:15px;color:var(--ios-primary-text);font-family:inherit;text-align:right}
    .form-input:focus{outline:none}
    
    /* Segmented Control for Meal Type */
    .meal-type-row{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;background:var(--ios-border);padding:2px;border-radius:8px;margin-bottom:20px}
    .mt-btn{background:var(--ios-bg);border:none;border-radius:6px;padding:6px 2px;font-size:13px;cursor:pointer;text-align:center;color:var(--ios-primary-text);font-weight:500}
    .mt-btn.sel{background:var(--ios-surface);box-shadow:0 1px 2px rgba(0,0,0,0.1);font-weight:600}

    .modal-btns{display:flex;gap:12px}
    .btn-cancel{flex:1;background:var(--ios-surface);border:none;border-radius:10px;padding:14px;font-size:16px;cursor:pointer;color:var(--ios-danger);font-weight:500}
    .btn-save{flex:2;background:var(--ios-accent);border:none;border-radius:10px;padding:14px;font-size:16px;font-weight:600;cursor:pointer;color:#ffffff}
    .btn-save:active,.btn-cancel:active{opacity:0.7}
    .hidden{display:none}
  </style>
</head>
<body>

<div class="app" id="app">
  <div class="header">
    <div class="header-top">
      <div class="month-nav">
        <button onclick="changeMonth(-1)">‹</button>
        <span class="month-title" id="monthTitle"></span>
        <button onclick="changeMonth(1)">›</button>
      </div>
      <span class="month-total" id="monthTotal">本月 $0</span>
    </div>
    <div class="weekdays">
      <span>日</span><span>一</span><span>二</span><span>三</span><span>四</span><span>五</span><span>六</span>
    </div>
    <div class="calendar" id="calendar"></div>
  </div>
  <div class="content" id="content"></div>
</div>

<div class="modal-overlay hidden" id="modalOverlay" onclick="closeIfOutside(event)">
  <div class="modal">
    <span class="modal-handle"></span>
    <div class="modal-title">記錄飲食</div>
    
    <div class="meal-type-row" id="mealTypeRow"></div>
    
    <div class="ios-list">
      <div class="form-group">
        <label class="form-label">食物名稱</label>
        <input class="form-input" id="foodName" placeholder="例如：叉燒飯、奶茶" />
      </div>
      <div class="form-group">
        <label class="form-label">價錢 (HKD)</label>
        <input class="form-input" id="foodPrice" type="number" placeholder="0" inputmode="decimal" />
      </div>
      <div class="form-group">
        <label class="form-label">備注</label>
        <input class="form-input" id="foodNote" placeholder="選填，例如：少甜" />
      </div>
    </div>
    
    <div class="modal-btns">
      <button class="btn-cancel" onclick="closeModal()">取消</button>
      <button class="btn-save" onclick="saveEntry()">記錄</button>
    </div>
  </div>
</div>

<script>
const MEAL_TYPES = ['早餐','午餐','下午茶','晚餐'];
const MEAL_ICONS = ['🌅','☀️','🍵','🌙'];

// 修正：獲取正確的本地時區 ISO 日期（避免格林威治 UTC 導致的跨日 Bug）
function getLocalDateString() {
  const t = new Date();
  const z = t.getTimezoneOffset() * 60 * 1000;
  const localTimeline = new Date(t - z);
  return localTimeline.toISOString().split('T')[0];
}

let state = {
  currentYear: new Date().getFullYear(),
  currentMonth: new Date().getMonth(),
  selectedDate: getLocalDateString(),
  selectedMeal: '午餐',
  data: {}
};

function loadData() {
  try { state.data = JSON.parse(localStorage.getItem('foodData') || '{}'); } catch(e) { state.data = {}; }
}
function saveData() {
  localStorage.setItem('foodData', JSON.stringify(state.data));
}

function getEntries(dateStr) { return state.data[dateStr] || []; }

// 移除數量計算法，預設每筆記錄為單件
function dayTotal(dateStr) {
  return getEntries(dateStr).reduce((s,e) => s + (parseFloat(e.price)||0), 0);
}

function monthTotal() {
  let total = 0;
  Object.keys(state.data).forEach(d => {
    if (d.startsWith(`${state.currentYear}-${String(state.currentMonth+1).padStart(2,'0')}`)) {
      total += dayTotal(d);
    }
  });
  return total;
}

function renderCalendar() {
  const yr = state.currentYear, mo = state.currentMonth;
  const today = getLocalDateString();
  const firstDay = new Date(yr, mo, 1).getDay();
  const daysInMonth = new Date(yr, mo+1, 0).getDate();
  const prevDays = new Date(yr, mo, 0).getDate();

  const months = ['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];
  document.getElementById('monthTitle').textContent = `${yr}年 ${months[mo]}`;
  document.getElementById('monthTotal').textContent = `本月 $${monthTotal().toFixed(0)}`;

  let html = '';
  for (let i = 0; i < firstDay; i++) {
    const d = prevDays - firstDay + 1 + i;
    html += `<div class="day-cell other-month"><span class="day-num">${d}</span></div>`;
  }
  for (let d = 1; d <= daysInMonth; d++) {
    const dateStr = `${yr}-${String(mo+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isToday = dateStr === today;
    const isSelected = dateStr === state.selectedDate;
    const entries = getEntries(dateStr);
    const amt = dayTotal(dateStr);
    let cls = 'day-cell';
    if (isToday) cls += ' today';
    if (isSelected) cls += ' selected';
    html += `<div class="${cls}" onclick="selectDate('${dateStr}')">
      <span class="day-num">${d}</span>
      ${entries.length > 0 ? `<span class="day-amt">$${amt.toFixed(0)}</span>` : ''}
    </div>`;
  }
  const remaining = 42 - firstDay - daysInMonth;
  for (let i = 1; i <= remaining && remaining < 7; i++) {
    html += `<div class="day-cell other-month"><span class="day-num">${i}</span></div>`;
  }
  document.getElementById('calendar').innerHTML = html;
  renderContent();
}

function renderContent() {
  const dateStr = state.selectedDate;
  const entries = getEntries(dateStr);
  const [yr, mo, da] = dateStr.split('-');
  const weekdays = ['日','一','二','三','四','五','六'];
  const dow = new Date(dateStr).getDay();
  const total = dayTotal(dateStr);

  const grouped = {};
  MEAL_TYPES.forEach(m => grouped[m] = []);
  entries.forEach(e => { if (!grouped[e.meal]) grouped[e.meal] = []; grouped[e.meal].push(e); });

  let entriesHtml = '';
  const hasEntries = entries.length > 0;

  if (hasEntries) {
    const mealCount = entries.length;
    const avgPrice = total / mealCount;
    entriesHtml += `<div class="stats-bar">
      <div class="stat-card"><div class="stat-label">今日支出</div><div class="stat-val" style="color:var(--ios-accent)">$${total.toFixed(0)}</div></div>
      <div class="stat-card"><div class="stat-label">餐數</div><div class="stat-val">${mealCount}次</div></div>
      <div class="stat-card"><div class="stat-label">平均/餐</div><div class="stat-val">$${avgPrice.toFixed(0)}</div></div>
    </div>`;

    MEAL_TYPES.forEach((meal, mi) => {
      const items = grouped[meal];
      if (!items || items.length === 0) return;
      entriesHtml += `<div class="meal-section">
        <div class="meal-section-title">${MEAL_ICONS[mi]} ${meal}</div>`;
      items.forEach((e, idx) => {
        const realIdx = entries.indexOf(e);
        // 移除數量後，直接顯示單筆價格
        const subtotal = parseFloat(e.price) || 0; 
        entriesHtml += `<div class="entry-card">
          <div class="entry-info">
            <div class="entry-name">${e.name}</div>
            <div class="entry-meta">${e.note ? e.note : ''}</div>
          </div>
          <span class="entry-price">$${subtotal.toFixed(0)}</span>
          <button class="entry-del" onclick="deleteEntry('${dateStr}',${realIdx})" aria-label="刪除"><i class="ti ti-trash" aria-hidden="true"></i></button>
        </div>`;
      });
      entriesHtml += '</div>';
    });
  } else {
    entriesHtml = `<div class="empty-state"><i class="ti ti-tools-kitchen-2" aria-hidden="true"></i><p>今天未有記錄<br>記下你吃了什麼吧！</p></div>`;
  }

  document.getElementById('content').innerHTML = `
    <div class="date-header">
      <span class="date-label">${parseInt(mo)}月${parseInt(da)}日（週${weekdays[dow]}）</span>
      ${hasEntries ? `<span class="day-total">$${total.toFixed(0)}</span>` : ''}
    </div>
    <button class="add-btn" onclick="openModal()">
      <i class="ti ti-plus" aria-hidden="true"></i> 新增飲食記錄
    </button>
    ${entriesHtml}`;
}

function selectDate(dateStr) {
  state.selectedDate = dateStr;
  renderCalendar();
}

function changeMonth(dir) {
  state.currentMonth += dir;
  if (state.currentMonth > 11) { state.currentMonth = 0; state.currentYear++; }
  if (state.currentMonth < 0) { state.currentMonth = 11; state.currentYear--; }
  renderCalendar();
}

function openModal() {
  state.selectedMeal = '午餐';

  const mealRow = document.getElementById('mealTypeRow');
  mealRow.innerHTML = MEAL_TYPES.map((m,i) =>
    `<button class="mt-btn${m===state.selectedMeal?' sel':''}" onclick="selectMeal('${m}')">${m}</button>`
  ).join('');

  document.getElementById('foodName').value = '';
  document.getElementById('foodPrice').value = '';
  document.getElementById('foodNote').value = '';
  document.getElementById('modalOverlay').classList.remove('hidden');
  setTimeout(() => document.getElementById('foodName').focus(), 100);
}

function closeModal() {
  document.getElementById('modalOverlay').classList.add('hidden');
}

function closeIfOutside(e) {
  if (e.target === document.getElementById('modalOverlay')) closeModal();
}

function selectMeal(meal) {
  state.selectedMeal = meal;
  document.querySelectorAll('.mt-btn').forEach((b,i) => b.classList.toggle('sel', MEAL_TYPES[i] === meal));
}

function saveEntry() {
  const name = document.getElementById('foodName').value.trim();
  const price = parseFloat(document.getElementById('foodPrice').value) || 0;
  const note = document.getElementById('foodNote').value.trim();
  
  if (!name) { document.getElementById('foodName').focus(); return; }
  if (!state.data[state.selectedDate]) state.data[state.selectedDate] = [];
  
  // 移除物件中的 emoji 與 qty 屬性
  state.data[state.selectedDate].push({ name, meal: state.selectedMeal, price, note });
  saveData();
  closeModal();
  renderCalendar();
}

function deleteEntry(dateStr, idx) {
  if (!confirm('刪除這條記錄？')) return;
  state.data[dateStr].splice(idx, 1);
  if (state.data[dateStr].length === 0) delete state.data[dateStr];
  saveData();
  renderCalendar();
}

loadData();
renderCalendar();
</script>
</body>
</html>
